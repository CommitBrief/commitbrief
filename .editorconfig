root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.{yml,yaml,md,json,toml}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2

[*.{bat,ps1}]
end_of_line = crlf
