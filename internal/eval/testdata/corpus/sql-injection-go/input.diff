+// FindUserByName looks up a single user row by display name.
+func (s *Store) FindUserByName(name string) (*User, error) {
+	query := "SELECT id, name, email FROM users WHERE name = '" + name + "'"
+	row := s.db.QueryRow(query)
+	var u User
+	if err := row.Scan(&u.ID, &u.Name, &u.Email); err != nil {
+		return nil, err
+	}
+	return &u, nil
+}
